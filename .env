# ============================================================
#  Trip Visuals Wear — Environment Variables
#  Copy this file to .env for local development.
#  NEVER commit .env to GitHub — it contains secrets.
# ============================================================

# ── DATABASE (Railway PostgreSQL) ───────────────────────────
# Get this from Railway: your project → PostgreSQL → Connect
DATABASE_URL="postgresql://postgres:SfNtXcfOGIuaflrlTpdeOFIEXxnURuuH@postgres.railway.internal:5432/railway" 

# ── ADMIN PASSWORD ──────────────────────────────────────────
# The password used to log in to /login.html
# Use something strong — min 16 characters recommended
ADMIN_PASSWORD="TripVisuals@26"

# ── CLOUDINARY ──────────────────────────────────────────────
# Get these from cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME="dda80tcc4"
CLOUDINARY_API_KEY="641585734185664"
CLOUDINARY_API_SECRET="jybJruV83ev93rrT0L3SpESAv9M"

# ── SERVER ──────────────────────────────────────────────────
# Port the server listens on. Railway sets this automatically.
# Only needed for local development.
PORT=3000

# ── OPTIONAL: ERROR MONITORING ──────────────────────────────
# Sign up at sentry.io, create a Node.js project, copy the DSN.
# Leave empty to disable Sentry (it's fully optional).
# SENTRY_DSN=https://your_key@sentry.io/your_project_id

# ── PAGAMENTOS AUTOMÁTICOS (Asaas) ───────────────────────────
# Deixe tudo abaixo VAZIO até o CNPJ ser aprovado e a conta
# Asaas estar criada. Enquanto ASAAS_API_KEY estiver vazia, o
# checkout automático fica indisponível e o catálogo usa
# normalmente o fluxo de WhatsApp — nada muda até aqui ser
# preenchido E o flag 'checkout_automatico_enabled' ser ligado
# em /admin-pedidos.html. Veja ATIVACAO_PAGAMENTOS.md.
# ASAAS_API_KEY=
# ASAAS_ENVIRONMENT=sandbox
# ASAAS_WEBHOOK_TOKEN=
