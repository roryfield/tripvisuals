# server/.env.example — VoidZone WoW Ops v3.2
# Copie para .env e preencha os valores. NUNCA commite o .env real no git.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database (Railway PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@host:5432/database?sslmode=require

# ── Auth: JWT ─────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_UM_SECRET_DE_64_BYTES_AQUI

# Tempo de expiração do token (ex: 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# ── Auth: API Key (watcher daemon ↔ Railway) ──────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=GERE_UMA_API_KEY_AQUI

# ── CORS: URL do frontend no Hostinger ────────────────────────────────────────
# Sem barra final. Ex: https://meudominio.com
CLIENT_URL=https://SEU-DOMINIO-HOSTINGER.com

# ── Limites de usuários ───────────────────────────────────────────────────────
MAX_USERS=2

# ── Premium / Stripe (opcional, deixe vazio para desativar) ──────────────────
ENABLE_PREMIUM=false
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_WEBHOOK_SECRET=

# ── Google OAuth (opcional — para login com Google) ───────────────────────────
# Configurar em: https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL de callback (deve ser exatamente a mesma cadastrada no Google Console)
GOOGLE_CALLBACK_URL=https://SEU-APP.up.railway.app/auth/google/callback

# ── Watcher Daemon (usado no sync/watcher.js, não no servidor) ───────────────
# Estes são lidos pelo watcher, não pelo Express
API_BASE=https://SEU-APP.up.railway.app
WOW_SAVE_DIR=C:/Program Files (x86)/World of Warcraft/_classic_tbc_/WTF/Account/NOME/SavedVariables
WOW_REALM_KEY=Nightslayer-Horde
LOG_LEVEL=info
